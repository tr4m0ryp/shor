# Shor MCP connector (apps/mcp) — Cloud Run service image.
# A thin FastMCP translator over Shor's /external/* plane, exposed to Claude
# routines. No database, no offensive toolkit — just Python. Mirrors the
# enrichment-mcp image. Build context is the repo root; only apps/mcp is copied.
FROM python:3.12-slim

WORKDIR /app

# Dependencies first for layer caching.
COPY apps/mcp/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Application code.
COPY apps/mcp/src ./src

ENV MCP_HOST=0.0.0.0 \
    PYTHONUNBUFFERED=1

# Cloud Run injects $PORT (default 8080); config.py honors it. Serves /mcp.
CMD ["python", "-m", "src.shor_mcp"]
