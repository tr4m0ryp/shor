# Shor dashboard (apps/web) — Cloud Run service image.
# Small Node image (no offensive toolkit); builds the web app and serves it.
FROM node:22-slim AS build
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate
WORKDIR /app
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json ./
COPY infra/config ./infra/config
COPY apps/web/package.json ./apps/web/package.json
COPY apps/worker/package.json ./apps/worker/package.json
RUN pnpm install --frozen-lockfile
COPY apps/web ./apps/web
RUN pnpm --filter @shor/web build

FROM node:22-slim AS runtime
WORKDIR /app
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/web ./apps/web
COPY --from=build /app/package.json /app/pnpm-workspace.yaml ./
# Cloud Run sends traffic to $PORT (default 8080); the dashboard reads WEB_PORT.
ENV WEB_PORT=8080
ENV NODE_ENV=production
EXPOSE 8080
CMD ["node", "apps/web/dist/index.js"]
