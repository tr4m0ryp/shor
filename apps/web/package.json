{
  "name": "@aegis/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && (mkdir -p dist/db/migrations && cp src/db/migrations/*.sql dist/db/migrations/) && rm -rf dist/public && (cp -R src/public dist/public 2>/dev/null || true)",
    "check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "node dist/db/migrate.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.2",
    "@google-cloud/storage": "^7.19.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/request": "^10.0.10",
    "@temporalio/client": "^1.11.0",
    "google-auth-library": "^10.6.2",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/pg": "^8.11.0",
    "typescript": "^5.9.3"
  }
}
