{
  "extends": "../../infra/config/tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    // The MCP SDK is authored without exactOptionalPropertyTypes; relax it at this
    // leaf so SDK interop (transport options, Transport.onclose) needs no casts.
    // The base config keeps the flag on for apps/web and apps/worker.
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
